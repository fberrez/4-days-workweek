---
import "../styles/fdw.css";
import { trials } from "../lib/workweekData";

interface Props {
  title: string;
  description?: string;
  current?: string;
}

const {
  title,
  description = "The evidence-based case for a 4-day workweek — 60+ global trials, side-by-side.",
  current,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const skipLabel = "Skip to content";
const ogImageUrl = new URL(`/og/en/home.png`, Astro.site);
const isHome = !current;

// ---------- JSON-LD ----------
// Site & organisation
const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "The 4-Day Workweek",
  alternateName: "fourday.work",
  url: Astro.site?.toString(),
  inLanguage: "en",
  description,
  publisher: {
    "@type": "Organization",
    name: "The 4-Day Workweek",
    url: Astro.site?.toString(),
    logo: new URL("/favicon.svg", Astro.site).toString(),
  },
};

// Per-trial dataset entries (for the homepage only) — gives crawlers + LLMs
// a structured, citable list of every documented pilot.
const datasetLd = isHome
  ? {
      "@context": "https://schema.org",
      "@type": "Dataset",
      name: "Documented 4-day workweek trials, 2018–2026",
      description:
        "Curated dataset of 18 documented 4-day workweek pilots and trials across 15+ countries, with productivity, burnout, sick-days and continuation outcomes per trial.",
      url: canonicalUrl.toString(),
      keywords: [
        "4-day workweek",
        "four-day workweek",
        "shorter workweek",
        "100:80:100",
        "productivity",
        "burnout",
        "work-life balance",
      ],
      license: "https://creativecommons.org/licenses/by/4.0/",
      isAccessibleForFree: true,
      creator: {
        "@type": "Organization",
        name: "The 4-Day Workweek",
        url: Astro.site?.toString(),
      },
      variableMeasured: [
        "Productivity change (%)",
        "Burnout change (%)",
        "Sick days change (%)",
        "Turnover change (%)",
        "Revenue change (%)",
        "Continuation status (kept / reversed)",
      ],
      temporalCoverage: "2017/2026",
      spatialCoverage: "Global",
      hasPart: trials.map((t) => ({
        "@type": "DataDownload",
        name: t.name,
        contentUrl: t.url,
        encodingFormat: "text/html",
        description: `${t.name} (${t.country}, ${t.year}) — ${t.continued ? "still on a 4-day week" : "reversed"}. Model: ${t.model}.${t.productivity ? ` Productivity ${t.productivity > 0 ? "+" : ""}${t.productivity}%.` : ""}`,
      })),
    }
  : null;

// FAQ-like Q&A for LLM and rich-result eligibility (homepage only)
const faqLd = isHome
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "Does the 4-day workweek actually work?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes, in most documented trials. In the world's largest pilot (UK, 2022, 61 companies), 89% of organizations were still on a 4-day week one year later and 51% had made it permanent. Productivity held or improved, burnout dropped 71% and sick days dropped 65%.",
          },
        },
        {
          "@type": "Question",
          name: "What is the 100:80:100 model?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "100:80:100 is the 4 Day Week Global standard: 100% pay for 80% of the time, with a commitment to 100% productivity. Workers compress the same workload into 4 days at full salary.",
          },
        },
        {
          "@type": "Question",
          name: "Which countries have adopted a 4-day week as policy?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Iceland — ~86% of the workforce now on a 36-hour week via union agreements. Belgium — right-to-request a 4-day week became law in 2022. Spain — 2025 Council of Ministers bill cuts the standard workweek from 40 to 37.5 hours, awaiting parliament. Spain, Portugal, Germany, the UK, the US and South Africa have run government-backed or coordinated pilots.",
          },
        },
        {
          "@type": "Question",
          name: "Has any company reversed its 4-day workweek?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Bolt (US fintech) ended its 4-day week in 2023 after founder Ryan Breslow returned as CEO and dismantled the company's progressive HR policies during financial restructuring and layoffs — citing 'significant gaps in execution.' The pilot itself had strong support: 94% of workers wanted to keep it. Microsoft Japan's widely cited 2019 trial was a single-month pilot only — never extended to a permanent 4-day week.",
          },
        },
      ],
    }
  : null;

const breadcrumbLd = !isHome
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: Astro.site?.toString(),
        },
        {
          "@type": "ListItem",
          position: 2,
          name: title,
          item: canonicalUrl.toString(),
        },
      ],
    }
  : null;

const keywords = [
  "4-day workweek",
  "four-day workweek",
  "32-hour workweek",
  "100:80:100",
  "shorter workweek",
  "work-life balance",
  "burnout",
  "productivity",
  "UK pilot",
  "Iceland",
  "Microsoft Japan",
  "4 Day Week Global",
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content="The 4-Day Workweek" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="theme-color" content="#FF604D" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="The 4-Day Workweek" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${title} — ${description}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${title} — ${description}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Structured data: Site -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} is:inline />
    {datasetLd && (
      <script type="application/ld+json" set:html={JSON.stringify(datasetLd)} is:inline />
    )}
    {faqLd && (
      <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline />
    )}
    {breadcrumbLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline />
    )}
  </head>
  <body class="fdw" style="margin:0;background:var(--paper);">
    <a href="#main" class="skip-link">{skipLabel}</a>
    <div id="main">
      <slot />
    </div>
  </body>
</html>
