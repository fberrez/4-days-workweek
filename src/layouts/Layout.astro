---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { type Lang, langPrefix } from "../i18n";

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  current?: string;
}

const {
  title,
  description = "The evidence-based case for a 4-day workweek.",
  lang = "en",
  current,
} = Astro.props;

const otherLang: Lang = lang === "en" ? "fr" : "en";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

// Build hreflang alternate URL
const slug = current ?? "";
const enUrl = new URL(slug ? `/${slug}` : "/", Astro.site);
const frUrl = new URL(slug ? `/fr/${slug}` : "/fr", Astro.site);

const skipLabel = lang === "fr" ? "Aller au contenu" : "Skip to content";

// OG image path
const ogSlug = current || "home";
const ogImageUrl = new URL(`/og/${lang}/${ogSlug}.png`, Astro.site);
---

<!doctype html>
<html lang={lang} class="bg-white scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="fr" href={frUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang === "fr" ? "fr_FR" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "fr" ? "en_US" : "fr_FR"} />
    <meta property="og:site_name" content="4-Day Workweek" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,700;1,6..72,400&display=swap" rel="stylesheet" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <title>{title}</title>
  </head>
  <body class="text-gray-900 antialiased">
    <a href="#main" class="skip-link">{skipLabel}</a>
    <Nav lang={lang} current={current} />
    <main id="main" class="max-w-3xl mx-auto px-6 py-12">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
