---
import { comparison } from "../../lib/workweekData";
const days = ["M", "T", "W", "T", "F"];
const headlineStats: Array<[string, string]> = [
  ["+22%", "avg. productivity"],
  ["−65%", "sick days"],
  ["−71%", "burnout"],
  ["92%", "companies stayed"],
];
---

<section class="fdw-hero">
  <div class="fdw-eyebrow">Evidence from 60+ global trials · 2018 → 2026</div>
  <h1 class="fdw-headline is-roman fdw-hero-h1">
    Drop a day.<br />
    <span class="accent">Keep the work.</span> Keep the pay.<br />
    Keep your people.
  </h1>

  <p class="fdw-hero-lede">
    Across sixty-plus pilots in fifteen countries, the result is the same:
    revenue holds, burnout falls, and ninety-two percent of companies
    don't go back. Here's the data, and a calculator to figure out what it
    would mean for you.
  </p>

  <div class="fdw-week-pair">
    <div class="fdw-week-block five">
      <div class="fdw-week-label">The old week</div>
      <div class="fdw-week-days">
        {days.map((d, i) => (
          <span class={`day ${i < 5 ? "active" : "off"}`} style={`--i:${i}`}>{d}</span>
        ))}
      </div>
      <div class="fdw-week-metrics">
        <div>
          <div class="metric-label">Productivity</div>
          <div class="metric-value">100</div>
        </div>
        <div>
          <div class="metric-label">Satisfaction</div>
          <div class="metric-value">{comparison.five.satisfaction}%</div>
        </div>
      </div>
    </div>

    <div class="fdw-arrow-wrap">
      <span class="fdw-arrow" aria-hidden="true">→</span>
    </div>

    <div class="fdw-week-block four">
      <div class="fdw-week-label">The new week</div>
      <div class="fdw-week-days">
        {days.map((d, i) => (
          <span class={`day ${i < 4 ? "active accent" : "off"}`} style={`--i:${i}`}>{d}</span>
        ))}
      </div>
      <div class="fdw-week-metrics">
        <div>
          <div class="metric-label">Productivity</div>
          <div class="metric-value">≥100</div>
        </div>
        <div>
          <div class="metric-label">Satisfaction</div>
          <div class="metric-value">{comparison.four.satisfaction}%</div>
        </div>
      </div>
    </div>
  </div>

  <div class="fdw-hero-stats">
    {headlineStats.map(([n, l]) => (
      <div>
        <div class="big">{n}</div>
        <div class="lbl">{l.toUpperCase()}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .fdw-hero {
    padding: 64px 48px 96px;
    background: var(--paper);
  }
  .fdw-hero-h1 {
    font-size: clamp(48px, 8vw, 128px);
    line-height: 0.96;
    margin-top: 24px;
    max-width: 1280px;
  }
  .fdw-hero-h1 .accent { color: var(--accent); }
  .fdw-hero-lede {
    font-family: var(--font-editorial);
    font-size: clamp(17px, 1.4vw, 22px);
    line-height: 1.5;
    font-weight: 400;
    margin-top: 32px;
    max-width: 720px;
    color: var(--ink-2);
  }
  .fdw-week-pair {
    margin-top: 80px;
    display: grid;
    grid-template-columns: 1fr 60px 1fr;
    gap: 24px;
    align-items: stretch;
  }
  .fdw-week-block {
    border-radius: 20px;
    padding: 32px;
    display: flex;
    flex-direction: column;
  }
  .fdw-week-block.five { background: #fffcf6; }
  .fdw-week-block.four { background: #fff2f1; }
  .fdw-week-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: rgba(0, 0, 0, 0.5);
    text-transform: uppercase;
    font-weight: 500;
  }
  .fdw-week-days {
    display: flex;
    gap: 8px;
    margin-top: 24px;
    height: 120px;
  }
  .fdw-week-days .day {
    flex: 1;
    border-radius: 10px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 12px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    transition: all 0.6s var(--ease-standard);
    transition-delay: calc(var(--i, 0) * 80ms);
    opacity: 0;
    transform: translateY(8px);
  }
  .fdw-week-days .day.active {
    background: #33485d;
    color: #fff;
  }
  .fdw-week-days .day.active.accent { background: var(--accent); }
  .fdw-week-days .day.off {
    background: rgba(0, 0, 0, 0.04);
    border: 1px dashed rgba(0, 0, 0, 0.15);
    color: rgba(0, 0, 0, 0.3);
  }
  .fdw-week-block.is-in .day { opacity: 1; transform: none; }
  .fdw-week-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 32px;
  }
  .metric-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: rgba(0, 0, 0, 0.5);
    text-transform: uppercase;
  }
  .metric-value {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    margin-top: 4px;
    letter-spacing: -0.02em;
  }
  .fdw-arrow-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .fdw-arrow {
    width: 60px;
    height: 60px;
    border-radius: 999px;
    background: var(--accent);
    display: grid;
    place-items: center;
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    transition: transform 0.6s var(--ease-standard);
  }
  .fdw-arrow.is-spin {
    transform: rotate(360deg) scale(1.15);
  }
  .fdw-hero-stats {
    display: flex;
    gap: 56px;
    margin-top: 56px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .fdw-hero-stats > div { text-align: center; }
  .fdw-hero-stats .big {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4vw, 44px);
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .fdw-hero-stats .lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--ink-4);
    margin-top: 4px;
  }

  @media (max-width: 900px) {
    .fdw-hero { padding: 48px 24px 72px; }
    .fdw-week-pair {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .fdw-arrow-wrap { transform: rotate(90deg); padding: 8px 0; }
    .fdw-hero-stats { gap: 28px; }
  }
</style>

<script>
  const blocks = document.querySelectorAll<HTMLDivElement>(".fdw-week-block");
  blocks.forEach((b) => requestAnimationFrame(() => b.classList.add("is-in")));

  const arrow = document.querySelector<HTMLSpanElement>(".fdw-arrow");
  if (arrow) {
    let on = false;
    setInterval(() => {
      on = !on;
      arrow.classList.toggle("is-spin", on);
    }, 2200);
  }
</script>
