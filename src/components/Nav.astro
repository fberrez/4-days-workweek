---
import { getCollection } from "astro:content";
import { type Lang, t, langPrefix, slugFromId } from "../i18n";

interface Props {
  lang: Lang;
  current?: string;
}

const { lang, current } = Astro.props;
const allArticles = await getCollection("research");
const articles = allArticles
  .filter((a) => a.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

const otherLang: Lang = lang === "en" ? "fr" : "en";
const prefix = langPrefix(lang);
const otherPrefix = langPrefix(otherLang);

let otherPath: string;
if (current) {
  otherPath = `${otherPrefix}/${current}`;
} else {
  otherPath = otherPrefix || "/";
}

const menuLabel = lang === "fr" ? "Ouvrir le menu" : "Open menu";
---

<nav class="border-b border-gray-200 bg-white/80 backdrop-blur-sm sticky top-0 z-50" aria-label={lang === "fr" ? "Navigation principale" : "Main navigation"}>
  <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={prefix || "/"} class="font-serif text-xl font-bold text-gray-900 hover:text-accent transition-colors">
      {lang === "en" ? "4-Day Workweek" : "Semaine de 4 jours"}
    </a>
    <div class="flex items-center gap-4">
      <!-- Desktop nav -->
      <div class="hidden sm:flex items-center gap-6 text-sm" role="list">
        {articles.map((article) => (
          <a
            role="listitem"
            href={`${prefix}/${slugFromId(article.id)}`}
            aria-current={current === slugFromId(article.id) ? "page" : undefined}
            class:list={[
              "transition-colors",
              current === slugFromId(article.id)
                ? "text-accent font-semibold"
                : "text-gray-500 hover:text-gray-900",
            ]}
          >
            {article.data.title}
          </a>
        ))}
      </div>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="sm:hidden p-2 -mr-2 text-gray-500 hover:text-gray-900 transition-colors"
        aria-label={menuLabel}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path id="icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Language switcher -->
      <a
        href={otherPath}
        class="text-xs font-mono px-2 py-1 rounded border border-gray-200 text-gray-500 hover:text-gray-900 hover:border-gray-400 transition-all"
        aria-label={otherLang === "fr" ? "Passer en français" : "Switch to English"}
      >
        {otherLang.toUpperCase()}
      </a>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-gray-100 bg-white" role="navigation" aria-label={lang === "fr" ? "Menu mobile" : "Mobile menu"}>
    <div class="px-6 py-4 space-y-3">
      {articles.map((article) => (
        <a
          href={`${prefix}/${slugFromId(article.id)}`}
          aria-current={current === slugFromId(article.id) ? "page" : undefined}
          class:list={[
            "block py-2 text-sm transition-colors",
            current === slugFromId(article.id)
              ? "text-accent font-semibold"
              : "text-gray-600 hover:text-gray-900",
          ]}
        >
          {article.data.title}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const iconOpen = document.getElementById("icon-open")!;
  const iconClose = document.getElementById("icon-close")!;

  toggle.addEventListener("click", () => {
    const isOpen = menu.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
    iconOpen.classList.toggle("hidden");
    iconClose.classList.toggle("hidden");
  });
</script>
