---
import { getCollection } from "astro:content";

interface Props {
  current?: string;
}

const { current } = Astro.props;
const articles = (await getCollection("research")).sort((a, b) => a.data.order - b.data.order);
---

<nav class="border-b border-gray-200 bg-white/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-serif text-xl font-bold text-gray-900 hover:text-[#9a462a] transition-colors">
      4-Day Workweek
    </a>
    <div class="hidden sm:flex items-center gap-6 text-sm">
      {articles.map((article) => (
        <a
          href={`/${article.id}`}
          class:list={[
            "transition-colors",
            current === article.id
              ? "text-[#9a462a] font-semibold"
              : "text-gray-500 hover:text-gray-900",
          ]}
        >
          {article.data.title}
        </a>
      ))}
    </div>
  </div>
</nav>
