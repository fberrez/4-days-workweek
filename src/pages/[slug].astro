---
import Layout from "../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("research");
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<Layout title={`${article.data.title} — 4-Day Workweek`} description={article.data.description} current={article.id}>
  <div class="mb-8">
    <a href="/" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">&larr; Back to index</a>
  </div>

  <article class="prose prose-gray max-w-none prose-headings:font-serif prose-code:before:content-none prose-code:after:content-none prose-code:bg-gray-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono prose-pre:bg-gray-950 prose-pre:text-gray-100 prose-table:text-sm prose-th:text-left prose-a:text-[#9a462a] prose-a:no-underline hover:prose-a:underline prose-blockquote:border-[#9a462a]/30 prose-blockquote:text-gray-500">
    <Content />
  </article>
</Layout>
