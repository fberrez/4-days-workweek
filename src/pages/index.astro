---
import RedesignLayout from "../layouts/RedesignLayout.astro";
import Masthead from "../components/redesign/Masthead.astro";
import Hero from "../components/redesign/Hero.astro";
import Comparison from "../components/redesign/Comparison.astro";
import Atlas from "../components/redesign/Atlas.astro";
import Timeline from "../components/redesign/Timeline.astro";
import Calculator from "../components/redesign/Calculator.astro";
import TrialDB from "../components/redesign/TrialDB.astro";
import Movement from "../components/redesign/Movement.astro";
import RedesignFooter from "../components/redesign/RedesignFooter.astro";
---

<RedesignLayout
  title="The 4-Day Workweek — Evidence from 60+ global trials"
