---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { t, slugFromId } from "../../i18n";

const lang = "fr" as const;
const articles = (await getCollection("research"))
  .filter((a) => a.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title={`${t(lang, "site.title")} — Recherche & Preuves`} lang={lang}>
  <header class="mb-12">
    <h1 class="font-serif text-4xl font-bold mb-4">{t(lang, "site.title")}</h1>
    <p class="text-lg text-gray-500 leading-relaxed">{t(lang, "site.subtitle")}</p>
  </header>

  <section class="mb-16">
    <div class="grid gap-px bg-gray-200 border border-gray-200 rounded-lg overflow-hidden">
      <div class="grid sm:grid-cols-3 gap-px bg-gray-200">
        <div class="bg-white p-6">
          <div class="text-3xl font-bold text-[#9a462a] font-mono">+40%</div>
          <div class="text-sm text-gray-500 mt-1">{t(lang, "stat.productivity")}</div>
        </div>
        <div class="bg-white p-6">
          <div class="text-3xl font-bold text-[#9a462a] font-mono">-71%</div>
          <div class="text-sm text-gray-500 mt-1">{t(lang, "stat.burnout")}</div>
        </div>
        <div class="bg-white p-6">
          <div class="text-3xl font-bold text-[#9a462a] font-mono">92%</div>
          <div class="text-sm text-gray-500 mt-1">{t(lang, "stat.companies")}</div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-6">{t(lang, "nav.research")}</h2>
    <div class="space-y-6">
      {articles.map((article, i) => (
        <a href={`/fr/${slugFromId(article.id)}`} class="block group">
          <article class="border border-gray-200 rounded-lg p-6 hover:border-[#9a462a]/30 hover:bg-[#fbf9f4] transition-all">
            <div class="flex items-baseline gap-3 mb-2">
              <span class="text-xs font-mono text-gray-400">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="text-lg font-semibold group-hover:text-[#9a462a] transition-colors">
                {article.data.title}
              </h3>
            </div>
            <p class="text-sm text-gray-500 ml-7">{article.data.description}</p>
          </article>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-16 p-6 bg-gray-50 rounded-lg border border-gray-200">
    <h2 class="font-semibold mb-2">{t(lang, "about.title")}</h2>
    <p class="text-sm text-gray-500 leading-relaxed">
      {t(lang, "about.text")}
      <a href="https://github.com/fberrez/4-days-workweek" class="underline hover:text-gray-900">GitHub</a>.
    </p>
  </section>
</Layout>
