---
import RedesignLayout from "../layouts/RedesignLayout.astro";
import Masthead from "../components/redesign/Masthead.astro";
import RedesignFooter from "../components/redesign/RedesignFooter.astro";
---

<RedesignLayout
  title="404 — Page not found"
  description="The page you're looking for doesn't exist or has been moved."
  current="404"
>
  <Masthead />

  <section class="nf">
    <div class="nf-eyebrow fdw-eyebrow accent">Error 404 · Lost in transit</div>

    <h1 class="fdw-headline is-roman nf-h1">
      That page<br /><em class="nf-em">took the day off.</em>
    </h1>

    <p class="nf-lede">
      The address you tried doesn't lead anywhere. It may have been moved,
      retired, or never existed. The 4-day week, however, very much does —
      head back and read the evidence.
    </p>

    <div class="nf-actions">
      <a class="fdw-btn is-accent" href="/">← Back to the homepage</a>
      <a class="fdw-btn is-ghost" href="/#trials">Browse the trial database →</a>
    </div>

    <div class="nf-jumps">
      <div class="fdw-eyebrow nf-jumps-label">Jump to</div>
      <div class="nf-jumps-grid">
        <a href="/#compare"><span class="num">01</span><span>The 5 vs 4 comparison</span></a>
        <a href="/#atlas"><span class="num">02</span><span>The world atlas of pilots</span></a>
        <a href="/#timeline"><span class="num">03</span><span>A century of working hours</span></a>
        <a href="/#calculator"><span class="num">04</span><span>The savings calculator</span></a>
        <a href="/#trials"><span class="num">05</span><span>Every trial we found</span></a>
        <a href="/#movement"><span class="num">06</span><span>The movement &amp; policy</span></a>
      </div>
    </div>

    <div class="nf-marker" aria-hidden="true">404</div>
  </section>

  <RedesignFooter />
</RedesignLayout>

<style>
  .nf {
    position: relative;
    padding: 96px 48px 120px;
    background: var(--paper);
    overflow: hidden;
  }
  .nf-eyebrow {
    position: relative;
    z-index: 2;
  }
  .nf-h1 {
    font-size: clamp(56px, 9vw, 132px);
    line-height: 0.96;
    margin-top: 16px;
    max-width: 1100px;
    position: relative;
    z-index: 2;
  }
  .nf-em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 500;
    color: var(--accent);
  }
  .nf-lede {
    font-family: var(--font-editorial);
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: var(--ink-2);
    margin-top: 28px;
    max-width: 720px;
    position: relative;
    z-index: 2;
  }
  .nf-actions {
    margin-top: 40px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    position: relative;
    z-index: 2;
  }

  .nf-jumps {
    margin-top: 96px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    position: relative;
    z-index: 2;
  }
  .nf-jumps-label {
    color: var(--ink-3);
  }
  .nf-jumps-grid {
    margin-top: 18px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
  }
  .nf-jumps-grid a {
    display: flex;
    align-items: baseline;
    gap: 18px;
    padding: 18px 0;
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink);
    transition: color 0.15s var(--ease-standard), padding-left 0.15s var(--ease-standard);
  }
  .nf-jumps-grid a:hover {
    color: var(--accent);
    padding-left: 6px;
  }
  .nf-jumps-grid .num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-4);
    letter-spacing: 0.08em;
  }

  /* Decorative oversized 404 in the background */
  .nf-marker {
    position: absolute;
    right: -3vw;
    bottom: -8vw;
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(280px, 38vw, 620px);
    line-height: 0.82;
    letter-spacing: -0.05em;
    color: rgba(255, 96, 77, 0.08);
    pointer-events: none;
    user-select: none;
    z-index: 1;
  }

  @media (max-width: 900px) {
    .nf { padding: 72px 24px 96px; }
    .nf-jumps-grid { grid-template-columns: 1fr; }
    .nf-jumps-grid a { font-size: 17px; padding: 14px 0; gap: 14px; }
    .nf-marker { font-size: 280px; right: -8vw; bottom: -10vw; }
  }
</style>
